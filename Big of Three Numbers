import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();
        int b = sc.nextInt();
        int c = sc.nextInt();

        int biggest;

        if(a >= b && a >= c) {
            biggest = a;
        }
        else if(b >= a && b >= c) {
            biggest = b;
        }
        else {
            biggest = c;
        }

        System.out.println(biggest + " is a Biggest Number from the Given Numbers");

        sc.close();
    }
}
